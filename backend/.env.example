NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rsci_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20
JWT_SECRET=your_64_char_jwt_secret_here_change_this
JWT_REFRESH_SECRET=your_64_char_refresh_secret_here_change_this
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8081,http://localhost:19006
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=debug
LOG_DIR=./logs
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
FINANCIAL_YEAR_START_MONTH=4
GST_ENABLED=true
